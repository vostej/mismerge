{
	"name": "demo",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "concurrently --kill-others \"vite dev\" \"cd ../packages/core && npm run watch\"",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"gh-pages": "npx gh-pages -d build -t"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^0.0.17",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"concurrently": "^9.2.1",
		"gh-pages": "^6.3.0",
		"shiki": "^4.0.2",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.3",
		"vite-plugin-dynamic-import": "^1.5.0"
	},
	"dependencies": {
		"@vostej/core": "file:../packages/core"
	},
	"type": "module"
}
