{
	"name": "mismerge",
	"type": "module",
	"module": "esnext",
	"license": "MIT",
	"author": "BearToCode",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/vostej/mismerge.git"
	},
	"scripts": {
		"core": "cd packages/core && npm run dev",
		"demo": "cd demo && npm run dev",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "prettier --write . && eslint --fix .",
		"format": "prettier --write .",
		"check": "npm run check --workspaces --if-present",
		"test": "npm run test --workspaces --if-present",
		"build": "npm run build --workspaces --if-present",
		"publish": "npm run publish --workspaces --if-present",
		"publish-demo": "npm run build && cd demo && npm run gh-pages"
	},
	"workspaces": [
		"packages/core",
		"packages/adapter-react",
		"packages/adapter-solid",
		"demo"
	],
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"esbuild": "^0.27.4",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^2.46.1",
		"picomatch": "^4.0.4",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"semantic-release": "^25.0.3",
		"semantic-release-monorepo": "^8.0.2",
		"svelte": "^5.55.0",
		"vite": "^8.0.3"
	},
	"overrides": {
		"ajv": "6.14.0",
		"braces": "3.0.3",
		"flatted": "3.4.2",
		"js-yaml": "4.1.1",
		"micromatch": "4.0.8",
		"yaml": "1.10.3",
		"@sveltejs/kit": {
			"cookie": "0.7.0"
		},
		"@rollup/pluginutils": {
			"picomatch": "2.3.2"
		}
	},
	"lint-staged": {
		"*.{js,ts,svelte}": "eslint --cache --fix",
		"*.{js,ts,css,md,svelte,html,yml,json,cjs}": "prettier --write",
		"*.{js,ts}": "eslint --cache --fix",
		"*.{js,ts,css,md}": "prettier --write"
	},
	"release": {
		"plugins": [
			"@semantic-release/commit-analyzer",
			"@semantic-release/release-notes-generator",
			"@semantic-release/npm",
			["@semantic-release/github", {"successComment": false, "failComment": false, "releasedLabels": false}]
		]
	},
	"version": "0.0.0-development"
}
