{
	"name": "@mismerge/solid",
	"description": "Solid.js implementation of Mismerge",
	"version": "0.0.0",
	"type": "module",
	"author": "BearToCode",
	"license": "MIT",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build && publint",
		"prepublishOnly": "npm run build",
		"preview": "vite preview",
		"publish": "npx --no-install semantic-release -e semantic-release-monorepo"
	},
	"peerDependencies": {
		"@mismerge/core": "^1.2.0",
		"solid-js": "^1.0.0"
	},
	"devDependencies": {
		"@mismerge/core": "../core",
		"@types/node": "^18.16.3",
		"publint": "^0.1.9",
		"solid-js": "^1.9.12",
		"typescript": "^5.0.0",
		"vite": "^5.1.4",
		"vite-plugin-dts": "^3.7.3",
		"vite-plugin-solid": "^2.11.11"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		}
	}
}
