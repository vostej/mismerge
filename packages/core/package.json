{
	"name": "@vostej/core",
	"version": "0.0.1",
	"description": "A modern merge editor for the Web",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/BearToCode/mismerge.git"
	},
	"author": "BearToCode",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run package",
		"watch": "svelte-kit sync && svelte-package --watch",
		"preview": "vite preview",
		"package:svelte": "svelte-package",
		"package:web": "rollup -c",
		"package": "svelte-kit sync && npm run package:svelte && npm run package:web && publint",
		"prepublishOnly": "npm run package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"publish": "npx --no-install semantic-release -e semantic-release-monorepo"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"import": "./dist/index.js"
		},
		"./styles.css": {
			"import": "./dist/styles/styles.css",
			"default": "./dist/styles/styles.css"
		},
		"./light.css": {
			"import": "./dist/styles/light.css",
			"default": "./dist/styles/light.css"
		},
		"./dark.css": {
			"import": "./dist/styles/dark.css",
			"default": "./dist/styles/dark.css"
		},
		"./web": {
			"import": "./dist/web.js",
			"default": "./dist/web.js"
		},
		"./colors": {
			"import": "./dist/internal/editor/colors.js",
			"default": "./dist/internal/editor/colors.js"
		}
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"main": "./dist/index.js",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@babel/preset-env": "^7.29.2",
		"@rollup/plugin-babel": "^7.0.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-terser": "^1.0.0",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/svelte": "^5.2.8",
		"@types/diff": "^5.2.3",
		"dedent": "^1.7.2",
		"rollup": "^4.60.0",
		"rollup-plugin-svelte": "^7.2.3",
		"publint": "^0.3.18",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"svelte-preprocess": "^6.0.3",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.3",
		"vitest": "^4.1.2",
		"jsdom": "^26.1.0"
	},
	"type": "module",
	"dependencies": {
		"diff": "^5.2.2",
		"esm-env": "^1.2.2",
		"nanoid": "^5.1.7"
	},
	"keywords": [
		"editor",
		"merge-editor",
		"svelte",
		"web-merge-editor",
		"merge",
		"mismerge",
		"diff"
	]
}
